{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sta.schema.json",
  "title": "Structured Thoughts Automata (STA)",
  "description": "Compiled program: a state machine the runtime instantiates and the LLM executes. Produced by stlc --sta.",
  "type": "object",
  "properties": {
    "metadata": {
      "allOf": [
        {
          "$ref": "common/metadata.schema.json"
        },
        {
          "properties": {
            "format": {
              "const": "sta"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "entry_points": {
      "type": "object",
      "description": "Named entry points into the program.",
      "additionalProperties": {
        "$ref": "#/$defs/entry_point"
      }
    },
    "prompts": {
      "type": "object",
      "description": "All prompts in the program, keyed by name.",
      "additionalProperties": {
        "$ref": "#/$defs/prompt"
      }
    },
    "python_imports": {
      "type": "object",
      "description": "Python modules required by extern callables.",
      "additionalProperties": {
        "type": "object",
        "description": "Module path to callable mapping."
      }
    },
    "provenance": {
      "type": "object",
      "description": "Tracked-artifact parents, role -> hash. Empty for a root artifact like the STA. Serialized top-level so it is folded into the hash.",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{64}$"
      }
    }
  },
  "required": [
    "entry_points",
    "prompts",
    "provenance"
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "entry_point": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "Name of the prompt this entry point starts at."
        },
        "inputs": {
          "type": "object",
          "description": "Input parameter schemas, keyed by parameter name.",
          "additionalProperties": {
            "$ref": "#/$defs/entry_param"
          }
        },
        "outputs": {
          "type": "object",
          "description": "Output schemas, keyed by alias.",
          "additionalProperties": {
            "$ref": "#/$defs/entry_param"
          }
        }
      },
      "required": [
        "prompt",
        "inputs",
        "outputs"
      ],
      "additionalProperties": false
    },
    "entry_param": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "length": {
          "type": "integer"
        },
        "max_length": {
          "type": "integer"
        },
        "items": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/entry_param"
            }
          ]
        },
        "min_items": {
          "type": "integer"
        },
        "max_items": {
          "type": "integer"
        },
        "enum": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "prompt": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "desc": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "flows": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/flow"
          }
        },
        "channels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/channel"
          }
        },
        "search": {
          "type": "object",
          "description": "Prompt-scope search params from `search { category.param is expr; }`. Intentionally OPEN (experimentation surface): categories (completion/choice/branch/queue or \"\") map to open param objects; resolved/validated downstream at instantiation, not here.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "number",
                "string",
                "boolean",
                "null"
              ]
            }
          }
        },
        "abstracts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/abstract_state"
          }
        },
        "vocabs": {
          "type": "object",
          "description": "Vocab table: vocab_<hash> -> vocab expression tree.",
          "additionalProperties": {
            "$ref": "#/$defs/vocab_expr"
          }
        }
      },
      "required": [
        "name",
        "desc",
        "fields",
        "abstracts",
        "flows",
        "channels"
      ],
      "additionalProperties": false
    },
    "field": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "depth": {
          "type": "integer",
          "minimum": 0
        },
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "flat_index": {
          "type": "integer",
          "minimum": 0
        },
        "desc": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "format": {
          "$ref": "#/$defs/field_format"
        },
        "format_ref": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "format_desc": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "range": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "integer"
              },
              "minItems": 2,
              "maxItems": 2
            },
            {
              "type": "null"
            }
          ]
        },
        "search": {
          "$ref": "#/$defs/search_policy"
        }
      },
      "required": [
        "name",
        "depth",
        "index",
        "flat_index",
        "desc",
        "format",
        "range"
      ],
      "additionalProperties": false
    },
    "field_format": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "completion",
            "enum",
            "choice",
            "record"
          ]
        },
        "length": {
          "type": "integer",
          "minimum": 0
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mode": {
          "type": "string"
        },
        "path": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "range": {
                    "oneOf": [
                      {
                        "type": "array"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "name"
                ],
                "additionalProperties": false
              }
            ]
          }
        },
        "vocab": {
          "type": "string",
          "description": "Reference into the prompt vocab table (vocab_<hash>)."
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "state": {
      "type": "object",
      "properties": {
        "field": {
          "type": "integer"
        },
        "indices": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "successors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "field",
        "indices",
        "successors"
      ],
      "additionalProperties": false
    },
    "flow": {
      "oneOf": [
        {
          "$ref": "#/$defs/flow_control"
        },
        {
          "$ref": "#/$defs/flow_return"
        }
      ]
    },
    "flow_control": {
      "type": "object",
      "properties": {
        "type": {
          "const": "control"
        },
        "prompt": {
          "type": "string"
        },
        "limit": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "type",
        "prompt"
      ],
      "additionalProperties": false
    },
    "flow_return": {
      "type": "object",
      "properties": {
        "type": {
          "const": "return"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/return_field"
          }
        }
      },
      "required": [
        "type",
        "fields"
      ],
      "additionalProperties": false
    },
    "return_field": {
      "type": "object",
      "properties": {
        "alias": {
          "type": "string"
        },
        "path": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "index": {
                "type": "integer"
              }
            },
            "required": [
              "name"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "alias",
        "path"
      ],
      "additionalProperties": false
    },
    "channel": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "input",
            "dataflow",
            "call"
          ]
        },
        "target": {
          "$ref": "#/$defs/path_steps"
        },
        "source": {
          "$ref": "#/$defs/path_steps"
        },
        "prompt": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "entry": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "extern": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "kwargs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/channel_kwarg"
          }
        },
        "clauses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/channel_clause"
          }
        }
      },
      "required": [
        "type",
        "target"
      ],
      "additionalProperties": false
    },
    "path_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "index": {
            "type": "integer",
            "description": "Index selector -> scalar element."
          },
          "slice": {
            "type": "array",
            "description": "Slice selector -> list. [lower, upper]; null = open bound.",
            "items": {
              "oneOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ]
            },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      }
    },
    "channel_kwarg": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "is_input": {
          "type": "boolean"
        },
        "path": {
          "$ref": "#/$defs/path_steps"
        },
        "prompt": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "value": {},
        "clauses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/channel_clause"
          }
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "channel_clause": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "bind",
            "prune",
            "ravel",
            "wrap",
            "mapped"
          ]
        },
        "source": {
          "$ref": "#/$defs/path_steps"
        },
        "target": {
          "$ref": "#/$defs/path_steps"
        },
        "depth": {
          "type": "integer",
          "description": "Ravel flatten depth (omitted = default 1)."
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "search_policy": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": [
            "number",
            "integer",
            "string",
            "boolean",
            "null"
          ]
        }
      }
    },
    "abstract_state": {
      "type": "object",
      "properties": {
        "field": {
          "type": "integer"
        },
        "flow": {
          "type": "integer"
        },
        "exit": {
          "type": "integer"
        }
      },
      "required": [
        "field",
        "flow",
        "exit"
      ],
      "additionalProperties": false
    },
    "vocab_expr": {
      "type": "object",
      "description": "Vocab expression tree node.",
      "properties": {
        "kind": {
          "enum": [
            "tokenize",
            "regex",
            "union",
            "intersect",
            "diff",
            "complement"
          ]
        },
        "strings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/vocab_expr"
          }
        }
      },
      "required": [
        "kind"
      ],
      "additionalProperties": false
    }
  }
}