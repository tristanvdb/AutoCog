{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "search.schema.json",
  "title": "AutoCog Search Configuration",
  "description": "Search parameters for completion, choice, and text evaluation strategies.",
  "type": "object",
  "properties": {
    "completion": {
      "type": "object",
      "description": "Parameters for text completion (beam search).",
      "properties": {
        "beams":      { "type": "integer", "minimum": 0, "description": "Number of beams (0 = disabled)." },
        "ahead":      { "type": "integer", "minimum": 0, "description": "Look-ahead depth (0 = disabled)." },
        "width":      { "type": "integer", "minimum": 1, "description": "Beam width." },
        "threshold":  { "type": "number", "description": "Probability threshold for pruning." },
        "repetition": {
          "oneOf": [{ "type": "number" }, { "type": "null" }],
          "description": "Repetition penalty (null = disabled)."
        },
        "diversity": {
          "oneOf": [{ "type": "number" }, { "type": "null" }],
          "description": "Diversity penalty (null = disabled)."
        },
        "stop": { "type": "string", "description": "Stop sequence for completions." }
      },
      "required": ["beams", "ahead", "width", "threshold", "stop"],
      "additionalProperties": false
    },
    "choice": {
      "type": "object",
      "description": "Parameters for choice (enum/select) evaluation.",
      "properties": {
        "threshold": { "type": "number", "description": "Probability threshold." },
        "width":     { "type": "integer", "minimum": 1, "description": "Top-k width." }
      },
      "required": ["threshold", "width"],
      "additionalProperties": false
    },
    "text": {
      "type": "object",
      "description": "Parameters for raw text evaluation.",
      "properties": {
        "evaluate": { "type": "boolean", "description": "Whether to evaluate text tokens." }
      },
      "required": ["evaluate"],
      "additionalProperties": false
    }
  },
  "required": ["completion", "choice", "text"],
  "additionalProperties": false
}
