// Fixture for `--emit symbols`: includes every symbol kind the serializer
// distinguishes (define, argument, vocab, record, prompt, python, alias) so
// serialize_symbols' type arms are exercised.
from "lib.py" import helper;
define d = 1;
argument a = 2;
vocab v = tokenize("x");
record R { is enum("p", "q"); }
prompt pr { is { f is text<length=4>; } return { use f; } }
export pr as main;
