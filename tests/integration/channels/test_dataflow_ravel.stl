// Test: dataflow with ravel — flatten nested arrays
//
// producer has items[3], each with sub[2] = nested array structure
// consumer wants a flat list of all sub values
//
// Input: {"count": 3}
// Expected: consumer.flat_list is a flattened array of all sub values

prompt producer {
  is {
    items[3] is {
      label is text<length=10>;
      sub[2] is text<length=5>;
    }
  }
  channel {
    items get items;
  }
  flow consumer;
}

prompt consumer {
  is {
    flat_list[6] is text<length=5>;
    summary is text<length=20>;
  }
  channel {
    flat_list use producer.items.sub ravel;
  }
  return {
    use summary;
  }
}

export producer as main;
