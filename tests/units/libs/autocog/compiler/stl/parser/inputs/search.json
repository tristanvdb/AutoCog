[
  {
    "description": "Empty search block",
    "tag": "Search",
    "code": "search { }",
    "should_pass": true
  },
  {
    "description": "Search with single parameter",
    "tag": "Search",
    "code": "search { custom_field is 0.7; }",
    "should_pass": true
  },
  {
    "description": "Search with integer parameter",
    "tag": "Search",
    "code": "search { custom_count is 100; }",
    "should_pass": true
  },
  {
    "description": "Search with string parameter",
    "tag": "Search",
    "code": "search { custom_name is \"some-value\"; }",
    "should_pass": true
  },
  {
    "description": "Search with boolean parameter",
    "tag": "Search",
    "code": "search { custom_flag is true; }",
    "should_pass": true
  },
  {
    "description": "Search with multiple parameters",
    "tag": "Search",
    "code": "search { custom_a is 0.8; custom_b is 500; custom_c is \"some-value\"; }",
    "should_pass": true
  },
  {
    "description": "Search with identifier value",
    "tag": "Search",
    "code": "search { custom_field is default_value; }",
    "should_pass": true
  },
  {
    "description": "Search with expression value",
    "tag": "Search",
    "code": "search { custom_field is (base * 2); }",
    "should_pass": true
  },
  {
    "description": "Search with nested path parameter",
    "tag": "Search",
    "code": "search { category.custom_field is 0.5; }",
    "should_pass": true
  },
  {
    "description": "Search with deep nested path",
    "tag": "Search",
    "code": "search { category.sub.custom_field is \"latest\"; }",
    "should_pass": true
  },
  {
    "description": "Search with underscore in parameter name",
    "tag": "Search",
    "code": "search { custom_length is 1000; }",
    "should_pass": true
  },
  {
    "description": "Search with numbers in parameter name",
    "tag": "Search",
    "code": "search { custom1 is \"value\"; custom2 is 42; }",
    "should_pass": true
  },
  {
    "description": "Search with f-string value",
    "tag": "Search",
    "code": "search { custom_field is f\"Generate {n} items\"; }",
    "should_pass": true
  },
  {
    "description": "Search with negative number",
    "tag": "Search",
    "code": "search { custom_offset is -10; }",
    "should_pass": true
  },
  {
    "description": "Search with float value",
    "tag": "Search",
    "code": "search { custom_threshold is 0.95; }",
    "should_pass": true
  },
  {
    "description": "Search with conditional expression",
    "tag": "Search",
    "code": "search { custom_field is (debug ? \"verbose\" : \"quiet\"); }",
    "should_pass": true
  },
  {
    "description": "Search with complex nested expression",
    "tag": "Search",
    "code": "search { custom_field is ((width + margin) * (height + margin)); }",
    "should_pass": true
  },
  {
    "description": "Search with all parameter types",
    "tag": "Search",
    "code": "search { custom_str is \"text\"; custom_num is 42; custom_float is 3.14; custom_bool is false; custom_expr is (a + b); }",
    "should_pass": true
  },
  {
    "description": "Search missing 'is' keyword - fails",
    "tag": "Search",
    "code": "search { custom_field 0.7; }",
    "should_pass": false
  },
  {
    "description": "Search missing value - fails",
    "tag": "Search",
    "code": "search { custom_field is; }",
    "should_pass": false
  },
  {
    "description": "Search missing semicolon - fails",
    "tag": "Search",
    "code": "search { custom_a is 0.7 custom_b is 100; }",
    "should_pass": false
  },
  {
    "description": "Search with unclosed block - fails",
    "tag": "Search",
    "code": "search { custom_field is 0.7;",
    "should_pass": false
  },
  {
    "description": "Search without block - fails",
    "tag": "Search",
    "code": "search custom_field is 0.7",
    "should_pass": false
  },
  {
    "description": "Search with keyword as locator segment - allowed",
    "tag": "Search",
    "code": "search { flow.threshold is 0.1; }",
    "should_pass": true
  },
  {
    "description": "Search with number starting parameter name - fails",
    "tag": "Search",
    "code": "search { 123param is \"value\"; }",
    "should_pass": false
  },
  {
    "description": "Search with array index in path - fails",
    "tag": "Search",
    "code": "search { items[0] is \"first\"; }",
    "should_pass": false
  },
  {
    "description": "Search with range in path - fails",
    "tag": "Search",
    "code": "search { data[1:5] is \"subset\"; }",
    "should_pass": false
  }
