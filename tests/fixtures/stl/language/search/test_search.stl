// Test the search statement: categorized params carried into the IR.
// Categories: text.* / enum.* / branch.* / flow.* / queue.*  (plus bare params
// under the "" category). RHS are compile-time expressions. These are carried
// opaquely into the IR/STA; defaults + resolution happen at instantiation.

define base_threshold = 0.1;

// File-level search defaults
search {
  text.threshold is base_threshold;
  queue.metric is "perplexity";
}

record Message {
  is text<length=50>;

  search {
    text.beams is 4;
    text.ahead is 2;
  }
}

record SpecialText {
  is text<length=50>;

  search {
    text.width is 1;
    branch.threshold is (base_threshold * 2);
  }
}

prompt main {
  is {
    greeting is Message;
    creative is SpecialText;

    // Inline struct with its own search policy and annotation, plus a nested
    // self-form inline struct field (exercises the inline-struct cascade,
    // self-form collapse, and inline annotate).
    details is {
      note is text<length=30>;
      scored is {
        is text<length=20>;
        search {
          text.beams is 2;
        }
      }
      annotate "extra detail block";
      search {
        text.threshold is 0.3;
        enum.width is 2;
      }
    }
  }

  search {
    text.threshold is 0.2;
    enum.width is 3;
    branch.width is 2;
    flow.threshold is 0.05;
    queue.metric is "mean_logprob";
  }

  channel {
    greeting get greeting;
    creative get creative;
  }

  return {
    use greeting;
    use creative;
  }
}
