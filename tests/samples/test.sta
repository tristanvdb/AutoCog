format sentence {
    is text<50, beams=5, width=3>;
    annotate f"Single well formed sentence in correct english";
}

format thought {
    is text<20, beams=5, width=2>;
    annotate f"Working through figuring out an answer. No need to use proper sentences.";
}

format boolean {
    is enum("True","False");
    annotate f"A boolean value to specify True or False";
}

prompt main {
    is {
        statement is sentence;
        work[1:5] is thought;
        correct is boolean;
    }
    channel {
        to .statement from ?statement;
    }
    return {
        from .correct;
    }
    annotate {
        _ as "You are verifying whether statements are true or false. Each prompt ends with a new line.";
        .statement as "the statement that you must verify";
        .work   as "up to five items that show what you consider to make that decision";
        .correct   as "your decision whether it is true or false";
    }
}
